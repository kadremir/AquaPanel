-- Trigger to auto-calculate taxes when a bill is inserted
CREATE OR REPLACE FUNCTION calculate_bill_taxes()
RETURNS TRIGGER AS $$
BEGIN
  IF NEW.base_amount IS NOT NULL THEN
    INSERT INTO bill_taxes (bill_id, tax_type, tax_rate, tax_amount)
    VALUES
      (NEW.id, 'VAT', 0.15, NEW.base_amount * 0.15),
      (NEW.id, 'Environmental', 0.05, NEW.base_amount * 0.05);
  END IF;
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER on_insert_bill_tax
AFTER INSERT ON public.bills
FOR EACH ROW
EXECUTE FUNCTION calculate_bill_taxes();
